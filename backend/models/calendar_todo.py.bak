from extensions import db
from datetime import datetime, timezone


class CalendarTodo(db.Model):
    __tablename__ = 'calendar_todos'

    id = db.Column(db.Integer, primary_key=True)
    user_id = db.Column(db.Integer, db.ForeignKey('users.id'), nullable=False, index=True)
    date = db.Column(db.Date, nullable=False, index=True)     # 归属日期
    title = db.Column(db.String(200), nullable=False)
    done = db.Column(db.Boolean, default=False)
    color = db.Column(db.String(7), nullable=False)
    sort_order = db.Column(db.Integer, default=0)
    reminder_at = db.Column(db.DateTime, nullable=True)       # 提醒时间
    reminded = db.Column(db.Boolean, default=False)           # 是否已提醒
    created_at = db.Column(db.DateTime, default=lambda: datetime.now(timezone.utc))
    updated_at = db.Column(db.DateTime, default=lambda: datetime.now(timezone.utc),
                           onupdate=lambda: datetime.now(timezone.utc))

    def to_dict(self):
        return {
            'id': self.id,
            'user_id': self.user_id,
            'date': self.date.isoformat() if self.date else None,
            'title': self.title,
            'done': self.done,
            'color': self.color,
            'sort_order': self.sort_order,
            'reminder_at': self.reminder_at.isoformat() if self.reminder_at else None,
            'reminded': self.reminded,
            'created_at': self.created_at.isoformat() if self.created_at else None,
            'updated_at': self.updated_at.isoformat() if self.updated_at else None,
        }
