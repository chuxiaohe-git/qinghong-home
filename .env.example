# ---- 轻鸿主页 环境变量示例 ----

# 后端密钥（必须修改）
SECRET_KEY=your-secret-key-here

# 数据库路径（默认 SQLite）
DATABASE_URL=sqlite:///instance/app.db

# AI 对话配置（可选）
# 在设置页 > AI 设置中配置，也可通过环境变量预设
# AI_API_URL=https://api.deepseek.com/v1/chat/completions
# AI_API_KEY=sk-your-api-key
# AI_MODEL=deepseek-chat

# 服务器配置
# HOST=0.0.0.0
# PORT=5000
